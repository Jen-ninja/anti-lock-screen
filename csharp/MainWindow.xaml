<Window x:Class="AntiLockScreen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:AntiLockScreen.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="300" Height="488"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <!-- 标题栏图标按钮（通用，hover 灰底） -->
        <Style x:Key="HeaderBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="{StaticResource HeaderIcon}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverSoft}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 关闭按钮（hover 红底） -->
        <Style x:Key="HeaderBtnClose" TargetType="Button" BasedOn="{StaticResource HeaderBtn}">
            <Setter Property="Foreground" Value="{StaticResource Red}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverClose}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 主开关按钮 -->
        <Style x:Key="ToggleMain" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 模式 chip -->
        <Style x:Key="ModeChip" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource ChipText}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{StaticResource ChipFg}" BorderBrush="{StaticResource ChipFg}" BorderThickness="2" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ChipHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentChipSel}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentChipText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 热键按钮 -->
        <Style x:Key="HkButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ChipFg}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ChipHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 文字按钮（恢复默认） -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" BorderBrush="{StaticResource EntryBorder}" BorderThickness="1" CornerRadius="6" Padding="10,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverSoft}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 设置开关（pill 样式 CheckBox） -->
        <Style x:Key="SettingSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Grid Width="36" Height="20">
                                <Border x:Name="track" Background="{StaticResource SwitchTrack}" CornerRadius="10"/>
                                <Border x:Name="knob" Width="16" Height="16" CornerRadius="8"
                                        Background="{StaticResource SwitchKnob}" HorizontalAlignment="Left"
                                        VerticalAlignment="Center" Margin="2,0,2,0"/>
                            </Grid>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="knob" Property="Background" Value="{StaticResource SwitchKnobHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="knob" Property="Margin" Value="18,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ===== 全屏卡片 ===== -->
        <Border x:Name="FullCard" CornerRadius="22" Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource Border}" BorderThickness="1">
            <Grid Margin="14,12,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Grid Grid.Row="0" x:Name="HeaderArea" Background="Transparent" Margin="0,0,0,2"
                      MouseLeftButtonDown="Header_MouseDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="22" Height="22" CornerRadius="7" Background="{StaticResource Accent}"/>
                        <TextBlock Text="防熄屏" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource Text}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnShrink" Style="{StaticResource HeaderBtn}" Click="BtnShrink_Click">
                            <Path Width="14" Height="14" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"
                                  Data="M2,6 L2,2 L6,2 M14,2 L18,2 L18,6 M18,14 L18,18 L14,18 M6,18 L2,18 L2,14"/>
                        </Button>
                        <Button x:Name="BtnMinimize" Style="{StaticResource HeaderBtn}" Click="BtnMinimize_Click">
                            <Path Width="14" Height="10" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"
                                  Data="M0,5 L10,5"/>
                        </Button>
                        <Button x:Name="BtnClose" Style="{StaticResource HeaderBtnClose}" Click="BtnClose_Click">
                            <Path Width="14" Height="14" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"
                                  Data="M0,0 L10,10 M10,0 L0,10"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 开关 -->
                <Button x:Name="ToggleBtn" Grid.Row="1" Style="{StaticResource ToggleMain}"
                        Content="开启防锁屏" Height="48" Margin="2,6,2,10" Click="ToggleBtn_Click"/>

                <!-- 模式 -->
                <TextBlock Grid.Row="2" Text="模式" FontSize="11" Foreground="{StaticResource Muted}" Margin="6,0,0,0"/>
                <Grid Grid.Row="3" Margin="-2,2,-2,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="ChipKeyboard" Grid.Column="0" Style="{StaticResource ModeChip}" GroupName="Mode" Height="64" Margin="4,0" Content="键盘" Click="Chip_Click"/>
                    <RadioButton x:Name="ChipMouse" Grid.Column="1" Style="{StaticResource ModeChip}" GroupName="Mode" Height="64" Margin="4,0" Content="鼠标" Click="Chip_Click"/>
                    <RadioButton x:Name="ChipApi" Grid.Column="2" Style="{StaticResource ModeChip}" GroupName="Mode" Height="64" Margin="4,0" Content="API" Click="Chip_Click"/>
                    <RadioButton x:Name="ChipHybrid" Grid.Column="3" Style="{StaticResource ModeChip}" GroupName="Mode" Height="64" Margin="4,0" Content="组合" Click="Chip_Click"/>
                </Grid>

                <!-- 间隔 -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="6,0,6,4">
                    <TextBlock Text="间隔（秒）" FontSize="11" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                    <TextBox x:Name="IntervalBox" Width="60" Margin="10,0" Height="26"
                             Background="{StaticResource EntryBg}" BorderBrush="{StaticResource EntryBorder}"
                             BorderThickness="1" Foreground="{StaticResource Text}" FontSize="12"
                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="2,0"
                             PreviewTextInput="IntervalBox_PreviewTextInput" DataObject.Pasting="IntervalBox_Pasting"
                             TextChanged="IntervalBox_TextChanged"/>
                    <TextBlock Text="（运行中可改）" FontSize="9" Foreground="{StaticResource Hint}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 热键·显隐 -->
                <Grid Grid.Row="5" Margin="6,0,6,4">
                    <TextBlock Text="热键·显隐窗口" FontSize="11" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                    <Button x:Name="HkShowBtn" Style="{StaticResource HkButton}" HorizontalAlignment="Right" Width="150"
                            Click="HkShow_Click"/>
                </Grid>

                <!-- 热键·开关 -->
                <Grid Grid.Row="6" Margin="6,0,6,4">
                    <TextBlock Text="热键·开关" FontSize="11" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                    <Button x:Name="HkRunBtn" Style="{StaticResource HkButton}" HorizontalAlignment="Right" Width="150"
                            Click="HkRun_Click"/>
                </Grid>

                <!-- 设置 -->
                <TextBlock Grid.Row="7" Text="设置" FontSize="11" Foreground="{StaticResource Muted}" Margin="6,0,0,0"/>
                <Grid Grid.Row="8" Margin="2,2,2,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <CheckBox Grid.Row="0" Grid.Column="0" x:Name="SwAutostart" Style="{StaticResource SettingSwitch}" Content="开机自启" Margin="4,3" Checked="SwAutostart_Changed" Unchecked="SwAutostart_Changed"/>
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="SwAutoon" Style="{StaticResource SettingSwitch}" Content="启动即开启" Margin="4,3" Checked="SwBool_Changed" Unchecked="SwBool_Changed"/>
                    <CheckBox Grid.Row="1" Grid.Column="0" x:Name="SwJitter" Style="{StaticResource SettingSwitch}" Content="随机抖动" Margin="4,3" Checked="SwBool_Changed" Unchecked="SwBool_Changed"/>
                    <CheckBox Grid.Row="1" Grid.Column="1" x:Name="SwNotify" Style="{StaticResource SettingSwitch}" Content="切换提示" Margin="4,3" Checked="SwBool_Changed" Unchecked="SwBool_Changed"/>
                </Grid>

                <!-- 状态 -->
                <Grid Grid.Row="10" Margin="6,4,6,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource DotOff}"/>
                        <TextBlock x:Name="StatusLabel" Text="已停止 · 等待开启" FontSize="11"
                                   Foreground="{StaticResource Muted}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="BtnReset" Style="{StaticResource LinkButton}" HorizontalAlignment="Right"
                            Content="恢复默认" Click="BtnReset_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ===== mini 台灯 ===== -->
        <Grid x:Name="MiniLamp" Background="Transparent" Visibility="Collapsed"
              MouseLeftButtonDown="Lamp_MouseDown" MouseMove="Lamp_MouseMove"
              MouseLeftButtonUp="Lamp_MouseUp" MouseRightButtonUp="Lamp_RightMouseUp">
            <ctrl:LampControl x:Name="LampMini" IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</Window>
